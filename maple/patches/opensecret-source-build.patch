+++ b/source-packages.nix
@@ -0,0 +1,250 @@
+{ pkgs }:
+
+let
+  lib = pkgs.lib;
+  awsStdenv = if pkgs ? gcc11Stdenv then pkgs.gcc11Stdenv else pkgs.stdenv;
+
+  mkAwsCmakePackage =
+    {
+      pname,
+      version,
+      owner ? "awslabs",
+      repo ? pname,
+      rev ? "v${version}",
+      hash,
+      buildInputs ? [ ],
+      propagatedBuildInputs ? buildInputs,
+      nativeBuildInputs ? [ ],
+      cmakeFlags ? [ ],
+      postInstall ? "",
+      env ? { },
+    }:
+    awsStdenv.mkDerivation {
+      inherit pname version postInstall env;
+
+      src = pkgs.fetchFromGitHub {
+        inherit owner repo rev hash;
+      };
+
+      nativeBuildInputs = [
+        pkgs.cmake
+        pkgs.ninja
+        pkgs.pkg-config
+      ] ++ nativeBuildInputs;
+
+      inherit buildInputs propagatedBuildInputs;
+
+      cmakeFlags = [
+        "-GNinja"
+        "-DBUILD_TESTING=OFF"
+        "-DBUILD_SHARED_LIBS=OFF"
+      ] ++ cmakeFlags;
+
+      doCheck = false;
+    };
+
+  aws-lc = awsStdenv.mkDerivation {
+    pname = "aws-lc";
+    version = "1.12.0";
+
+    src = pkgs.fetchFromGitHub {
+      owner = "aws";
+      repo = "aws-lc";
+      rev = "v1.12.0";
+      hash = "sha256-AqA0fIbBFk6SD533oTSXy9Kc7Fja8vgiiPTF00+V2MY=";
+    };
+
+    nativeBuildInputs = [
+      pkgs.cmake
+      pkgs.ninja
+    ];
+
+    cmakeFlags = [
+      "-GNinja"
+      "-DBUILD_SHARED_LIBS=OFF"
+      "-DBUILD_TESTING=OFF"
+      "-DDISABLE_GO=ON"
+      "-DDISABLE_PERL=ON"
+    ];
+
+    doCheck = false;
+  };
+
+  aws-c-common = mkAwsCmakePackage {
+    pname = "aws-c-common";
+    version = "0.8.0";
+    hash = "sha256-zxV+Rf0bUrWao5ALnqgAWMVsuGfLKQbQXvw/ppDMd28=";
+  };
+
+  awsCCommonCmakeFlags = [ "-DCMAKE_MODULE_PATH=${aws-c-common}/lib/cmake" ];
+
+  aws-c-sdkutils = mkAwsCmakePackage {
+    pname = "aws-c-sdkutils";
+    version = "0.1.2";
+    hash = "sha256-G+ykP39EmI8BCeulTsZ/OSFKRzXVbEK0+mtJ3tugl5M=";
+    buildInputs = [ aws-c-common ];
+    cmakeFlags = awsCCommonCmakeFlags;
+  };
+
+  aws-c-cal = mkAwsCmakePackage {
+    pname = "aws-c-cal";
+    version = "0.5.18";
+    hash = "sha256-sT5ahf8MuIhqDV6RrRU+RgsLdwVUDEFWRZJpzQJOPGA=";
+    buildInputs = [
+      aws-c-common
+      aws-lc
+    ];
+    cmakeFlags = awsCCommonCmakeFlags;
+  };
+
+  s2n-tls = mkAwsCmakePackage {
+    pname = "s2n-tls";
+    version = "1.3.46";
+    owner = "aws";
+    repo = "s2n-tls";
+    hash = "sha256-X+ZwM53ensCeUoxNa8cBO4KcWxWbb7iKxIRysImvKxw=";
+    buildInputs = [ aws-lc ];
+    cmakeFlags = [ "-DUNSAFE_TREAT_WARNINGS_AS_ERRORS=OFF" ];
+  };
+
+  aws-c-io = mkAwsCmakePackage {
+    pname = "aws-c-io";
+    version = "0.11.0";
+    hash = "sha256-LIrAA3+Yd0lhCMQ9R4HT/ZFKm3y9iSm3h5vcn0ghiPA=";
+    buildInputs = [
+      aws-c-common
+      aws-c-cal
+      s2n-tls
+      aws-lc
+    ];
+    cmakeFlags = awsCCommonCmakeFlags ++ [ "-DUSE_VSOCK=1" ];
+  };
+
+  aws-c-compression = mkAwsCmakePackage {
+    pname = "aws-c-compression";
+    version = "0.2.14";
+    hash = "sha256-bRNHjKhIpaWYToAFFUXUhyqYDmbL7SuZs2np/iH8Qzs=";
+    buildInputs = [ aws-c-common ];
+    cmakeFlags = awsCCommonCmakeFlags;
+  };
+
+  aws-c-http = mkAwsCmakePackage {
+    pname = "aws-c-http";
+    version = "0.7.6";
+    hash = "sha256-pJGzGbIuz8UJkfmTQEZgXSOMuYixMezNZmgaRlcnmfg=";
+    buildInputs = [
+      aws-c-common
+      aws-c-io
+      aws-c-compression
+    ];
+    cmakeFlags = awsCCommonCmakeFlags;
+  };
+
+  aws-c-auth = mkAwsCmakePackage {
+    pname = "aws-c-auth";
+    version = "0.6.15";
+    hash = "sha256-oLX/evqtKbs5/WpSUBdLdKWKD8tdWwP0iRONuMCVu/E=";
+    buildInputs = [
+      aws-c-common
+      aws-c-sdkutils
+      aws-c-cal
+      aws-c-io
+      aws-c-http
+    ];
+    cmakeFlags = awsCCommonCmakeFlags;
+  };
+
+  json-c = mkAwsCmakePackage {
+    pname = "json-c";
+    version = "0.16-20220414";
+    owner = "json-c";
+    repo = "json-c";
+    rev = "json-c-0.16-20220414";
+    hash = "sha256-KbnUWLgpg6/1wvXhUoYswyqDcgiwEcvgaWCPjNcX20o=";
+    cmakeFlags = [ "-DDISABLE_WERROR=ON" ];
+  };
+
+  nsm-lib = pkgs.rustPlatform.buildRustPackage {
+    pname = "aws-nitro-enclaves-nsm-api-nsm-lib";
+    version = "0.4.0";
+
+    src = pkgs.fetchFromGitHub {
+      owner = "aws";
+      repo = "aws-nitro-enclaves-nsm-api";
+      rev = "v0.4.0";
+      hash = "sha256-HxgQilQpKCRy8lmcjALIpwyAr1m1dcaUqcCL3D9JaCU=";
+    };
+
+    cargoLock = {
+      lockFile = ./nix/aws-nitro-enclaves-nsm-api-Cargo.lock;
+    };
+    cargoPatches = [ ./nix/aws-nitro-enclaves-nsm-api-Cargo-lock.patch ];
+    cargoBuildFlags = [
+      "-p"
+      "nsm-lib"
+    ];
+
+    doCheck = false;
+
+    installPhase = ''
+      runHook preInstall
+
+      mkdir -p $out/lib $out/include
+      libnsmSo="$(find target -type f -name libnsm.so | head -n1)"
+      libnsmA="$(find target -type f -name libnsm.a | head -n1)"
+      nsmH="$(find target -type f -name nsm.h | head -n1)"
+
+      test -n "$libnsmSo"
+      test -n "$libnsmA"
+      test -n "$nsmH"
+
+      install -m 755 "$libnsmSo" "$out/lib/libnsm.so"
+      install -m 644 "$libnsmA" "$out/lib/libnsm.a"
+      install -m 644 "$nsmH" "$out/include/nsm.h"
+
+      runHook postInstall
+    '';
+  };
+
+  aws-nitro-enclaves-sdk-c = mkAwsCmakePackage {
+    pname = "aws-nitro-enclaves-sdk-c";
+    version = "0-unstable-2024-03-06";
+    owner = "aws";
+    repo = "aws-nitro-enclaves-sdk-c";
+    rev = "00c6048945a3adbb84bd269f8388282d81110499";
+    hash = "sha256-tlit8ROuZ4CUNuT+jrcPLZoORG4bRPZiszMieGFvCzk=";
+    nativeBuildInputs = [ pkgs.git ];
+    buildInputs = [
+      json-c
+      nsm-lib
+      aws-c-common
+      aws-c-io
+      aws-c-http
+      aws-c-auth
+    ];
+    cmakeFlags = awsCCommonCmakeFlags;
+  };
+
+  nitro-bins-source = pkgs.runCommand "nitro-bins-source" { } ''
+    mkdir -p $out/{lib,bin}
+    install -m 755 ${nsm-lib}/lib/libnsm.so $out/lib/libnsm.so
+    install -m 755 ${aws-nitro-enclaves-sdk-c}/bin/kmstool_enclave_cli $out/bin/kmstool_enclave_cli
+  '';
+in
+{
+  inherit
+    aws-lc
+    aws-c-common
+    aws-c-sdkutils
+    aws-c-cal
+    s2n-tls
+    aws-c-io
+    aws-c-compression
+    aws-c-http
+    aws-c-auth
+    json-c
+    nsm-lib
+    aws-nitro-enclaves-sdk-c
+    nitro-bins-source
+    ;
+}
